{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://www.youtube.com/*", "*://*.reddit.com/*"],
      "js": ["content/detector.js", "content/renderer.js", "content/chrome-translator.js", "content/safari-translator.js", "content/floatball.js", "content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.reddit.com/*"],
      "js": ["content/detector.js", "content/renderer.js", "content/chrome-translator.js", "content/safari-translator.js", "content/floatball.js", "content/reddit.js", "content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content/youtube-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content/detector.js", "content/renderer.js", "content/chrome-translator.js", "content/safari-translator.js", "content/floatball.js", "content/youtube.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Privado — Bilingual Translator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
